generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  hashedPassword String
  role           String    @default("user") // admin, user
  avatar         String?
  onboarded      Boolean   @default(false)
  industry       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  leads          Lead[]
  contacts       Contact[]
  accounts       Account[]
  deals          Deal[]
  activities     Activity[]
  notes          Note[]
  tasks          Task[]
  integrations   Integration[]
  emailTemplates EmailTemplate[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  attachments    Attachment[]
}

model Integration {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String    // "google", "twilio"
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?
  email        String?   // Connected email for Google
  config       String?   // JSON string for provider-specific config
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, provider])
}

model Lead {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  company     String?
  title       String?
  status      String   @default("New") // New, Contacted, Qualified, Unqualified, Converted
  source      String?  // Web, Phone, Referral, Partner, Other
  rating      String?  // Hot, Warm, Cold
  address     String?
  city        String?
  state       String?
  zip         String?
  country     String?
  description String?
  ownerId     String?
  owner       User?    @relation(fields: [ownerId], references: [id])
  convertedContactId String?
  convertedAccountId String?
  convertedDealId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  activities  Activity[]
  notes       Note[]
  tasks       Task[]
  tags        Tag[]
}

model Contact {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  mobile      String?
  title       String?
  department  String?
  accountId   String?
  account     Account? @relation(fields: [accountId], references: [id])
  address     String?
  city        String?
  state       String?
  zip         String?
  country     String?
  description String?
  ownerId     String?
  owner       User?    @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deals       Deal[]
  activities  Activity[]
  notes       Note[]
  tasks       Task[]
  tags        Tag[]
}

model Account {
  id            String   @id @default(cuid())
  name          String
  industry      String?
  type          String?  // Prospect, Customer, Partner, Vendor, Other
  website       String?
  phone         String?
  address       String?
  city          String?
  state         String?
  zip           String?
  country       String?
  description   String?
  employees     Int?
  annualRevenue Float?
  ownerId       String?
  owner         User?    @relation(fields: [ownerId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  contacts      Contact[]
  deals         Deal[]
  activities    Activity[]
  notes         Note[]
  tasks         Task[]
  tags          Tag[]
}

model Pipeline {
  id        String   @id @default(cuid())
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stages    Stage[]
  deals     Deal[]
}

model Stage {
  id          String   @id @default(cuid())
  name        String
  pipelineId  String
  pipeline    Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  order       Int
  probability Int      @default(0) // 0-100
  color       String   @default("#3B82F6")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deals       Deal[]
}

model Deal {
  id          String   @id @default(cuid())
  name        String
  amount      Float?
  closeDate   DateTime?
  probability Int?
  type        String?  // New Business, Existing Business
  source      String?
  description String?
  stageId     String
  stage       Stage    @relation(fields: [stageId], references: [id])
  pipelineId  String
  pipeline    Pipeline @relation(fields: [pipelineId], references: [id])
  accountId   String?
  account     Account? @relation(fields: [accountId], references: [id])
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id])
  ownerId     String?
  owner       User?    @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  activities  Activity[]
  notes       Note[]
  tasks       Task[]
  tags        Tag[]
}

model Activity {
  id            String   @id @default(cuid())
  type          String   // task, call, email, meeting, note
  subject       String
  description   String?
  status        String   @default("Open") // Open, Completed, Cancelled
  dueDate       DateTime?
  priority      String?  // High, Medium, Low
  leadId        String?
  lead          Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contactId     String?
  contact       Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  accountId     String?
  account       Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  dealId        String?
  deal          Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  ownerId       String?
  owner         User?    @relation(fields: [ownerId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Note {
  id            String   @id @default(cuid())
  body          String
  leadId        String?
  lead          Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contactId     String?
  contact       Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  accountId     String?
  account       Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  dealId        String?
  deal          Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  ownerId       String?
  owner         User?    @relation(fields: [ownerId], references: [id])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("Open") // Open, In Progress, Completed, Cancelled
  priority    String    @default("Medium") // High, Medium, Low
  dueDate     DateTime?
  completedAt DateTime?

  // Relations - all optional, a task can be standalone
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#3B82F6")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads    Lead[]
  contacts Contact[]
  accounts Account[]
  deals    Deal[]
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String   // Lead, Contact, Account, Deal, Task
  entityId   String
  action     String   // create, update, delete
  changes    String?  // JSON string of field changes
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  type      String   // task_due, task_overdue, duplicate_found
  read      Boolean  @default(false)
  link      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Attachment {
  id         String   @id @default(cuid())
  filename   String
  filepath   String
  size       Int
  mimeType   String
  entityType String   // Lead, Contact, Account, Deal
  entityId   String
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id])
  createdAt  DateTime @default(now())
}

model CustomField {
  id         String   @id @default(cuid())
  name       String
  fieldType  String   // text, number, date, select, boolean
  entityType String   // Lead, Contact, Account, Deal
  options    String?  // JSON array for select type
  required   Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  values     CustomFieldValue[]
}

model CustomFieldValue {
  id            String      @id @default(cuid())
  value         String?
  customFieldId String
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  entityId      String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([customFieldId, entityId])
}

// ── Autonomous Agent System ──

model AgentConfig {
  id               String    @id @default(cuid())
  agentType        String    @unique // prospector, enricher, outreach, follow_up, pipeline_mover
  enabled          Boolean   @default(false)
  approvalRequired Boolean   @default(true)
  config           String?   // JSON — agent-specific settings
  schedule         String?   // "every_hour", "every_6_hours", "daily"
  lastRunAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model AgentRun {
  id          String    @id @default(cuid())
  agentType   String
  status      String    @default("running") // running, completed, failed
  summary     String?
  results     String?   // JSON
  error       String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
}

model AgentActivity {
  id          String   @id @default(cuid())
  agentType   String
  action      String   // found_lead, enriched_lead, sent_email, advanced_deal, booked_meeting, etc.
  description String
  entityType  String?  // Lead, Contact, Deal
  entityId    String?
  status      String   @default("completed") // completed, pending_approval, approved, rejected
  metadata    String?  // JSON
  createdAt   DateTime @default(now())
}

model IcpProfile {
  id              String   @id @default(cuid())
  name            String
  industries      String?  // JSON array
  companySize     String?  // "1-50", "51-200", "201-1000", "1000+"
  roles           String?  // JSON array of target job titles
  regions         String?  // JSON array
  keywords        String?  // JSON array
  excludeKeywords String?  // JSON array
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OutreachSequence {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("draft") // draft, active, paused, archived
  steps       String   // JSON array of { stepNumber, delayDays, type, subject, body, intent }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  enrollments OutreachEnrollment[]
}

model OutreachEnrollment {
  id          String            @id @default(cuid())
  sequenceId  String
  sequence    OutreachSequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  entityType  String            // Lead, Contact
  entityId    String
  currentStep Int               @default(0)
  status      String            @default("active") // active, paused, completed, replied, bounced, unsubscribed
  enrolledAt  DateTime          @default(now())
  lastStepAt  DateTime?
  nextStepAt  DateTime?

  @@unique([sequenceId, entityType, entityId])
}
